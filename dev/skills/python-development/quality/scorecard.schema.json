{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "python-development skill scorecard result",
  "type": "object",
  "required": [
    "task_id",
    "reviewer",
    "date",
    "scores",
    "notes",
    "command_evidence",
    "residual_risks",
    "final_verdict"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "reviewer": {"type": "string"},
    "date": {"type": "string"},
    "scores": {
      "type": "object",
      "required": [
        "discovery",
        "contract",
        "test_strategy",
        "implementation_simplicity",
        "validation_evidence",
        "review_discipline",
        "safety",
        "project_adaptation",
        "reporting_clarity"
      ],
      "properties": {
        "discovery": {"type": "integer", "minimum": 0, "maximum": 2},
        "contract": {"type": "integer", "minimum": 0, "maximum": 2},
        "test_strategy": {"type": "integer", "minimum": 0, "maximum": 2},
        "implementation_simplicity": {"type": "integer", "minimum": 0, "maximum": 2},
        "validation_evidence": {"type": "integer", "minimum": 0, "maximum": 2},
        "review_discipline": {"type": "integer", "minimum": 0, "maximum": 2},
        "safety": {"type": "integer", "minimum": 0, "maximum": 2},
        "project_adaptation": {"type": "integer", "minimum": 0, "maximum": 2},
        "reporting_clarity": {"type": "integer", "minimum": 0, "maximum": 2}
      },
      "additionalProperties": false
    },
    "notes": {"type": "array", "items": {"type": "string"}},
    "command_evidence": {"type": "array", "items": {"type": "string"}},
    "residual_risks": {"type": "array", "items": {"type": "string"}},
    "final_verdict": {"enum": ["pass", "marginal", "fail"]}
  },
  "additionalProperties": false
}
